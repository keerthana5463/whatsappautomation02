# ===========================================
# WhatsApp Cloud API Configuration
# ===========================================

# Get these from: https://developers.facebook.com/apps/YOUR_APP_ID/whatsapp-business/wa-dev-console
WHATSAPP_TOKEN=your_permanent_access_token_here
PHONE_NUMBER_ID=your_phone_number_id_here

# Custom string for webhook verification (you create this - any random string)
VERIFY_TOKEN=my_super_secret_verify_token_123

# ===========================================
# Typebot Configuration  
# ===========================================

# Your Typebot public ID (from the typebot URL)
# Example: If your bot URL is https://typebot.io/my-chatbot-123, then the ID is "my-chatbot-123"
TYPEBOT_PUBLIC_ID=your-typebot-id-here

# Use 'https://typebot.io' for Cloud or your own server URL for Self-Hosted
TYPEBOT_API_URL=https://typebot.io

# ===========================================
# Server Configuration
# ===========================================

PORT=3000
